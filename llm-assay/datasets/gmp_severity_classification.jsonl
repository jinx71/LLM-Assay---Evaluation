# GMP deviation severity classification.
# Task: classify each manufacturing deviation as Critical, Major, or Minor.
# Scored with exact_match (case-insensitive). System prompt lives in the config.
{"id": "sev-01", "task": "classification", "expected": "Critical", "input": "During an aseptic media fill validation run, two filled units showed visible turbidity on incubation, indicating microbial contamination of the Grade A filling line."}
{"id": "sev-02", "task": "classification", "expected": "Minor", "input": "An operator initialled a batch record entry but omitted the date; the correct date was confirmed from the adjacent automated equipment timestamp and corrected per the good documentation SOP."}
{"id": "sev-03", "task": "classification", "expected": "Major", "input": "The differential pressure between a Grade B and an adjacent Grade C cleanroom dropped below the validated limit for approximately 40 minutes during active processing of a sterile product."}
{"id": "sev-04", "task": "classification", "expected": "Critical", "input": "A sterilising-grade 0.22 micron filter used for a parenteral product failed the post-use integrity test, and the affected batch had already been filled and sealed."}
{"id": "sev-05", "task": "classification", "expected": "Minor", "input": "A printed cleaning log used an outdated form revision number, although all required cleaning steps were performed, recorded, and verified correctly."}
{"id": "sev-06", "task": "classification", "expected": "Major", "input": "A temperature excursion in a finished-goods cold room reached 12 degrees Celsius for two hours against a labelled storage requirement of 2 to 8 degrees Celsius, affecting released vaccine stock."}
{"id": "sev-07", "task": "classification", "expected": "Critical", "input": "Out-of-specification sterility test results were obtained for a released lot of injectable product that has already been distributed to hospitals."}
{"id": "sev-08", "task": "classification", "expected": "Major", "input": "Calibration of a critical process balance used for active ingredient dispensing was found to be 0.8 percent out of tolerance, and several batches were weighed since the last valid calibration."}
{"id": "sev-09", "task": "classification", "expected": "Minor", "input": "A label on a sampling bottle in the QC laboratory was slightly smudged but remained fully legible, and the sample identity was independently confirmed in the LIMS."}
{"id": "sev-10", "task": "classification", "expected": "Critical", "input": "A mix-up was discovered in which two different product strengths were packaged using the same lot of printed cartons, and the affected packs cannot be distinguished without opening."}
{"id": "sev-11", "task": "classification", "expected": "Major", "input": "An environmental monitoring plate from a Grade A zone exceeded the action limit for total viable count during routine production of a sterile ophthalmic product."}
{"id": "sev-12", "task": "classification", "expected": "Minor", "input": "A non-product-contact utility gauge in the technical area was found past its calibration due date by three days, with no impact on any batch or product quality attribute."}
{"id": "sev-13", "task": "classification", "expected": "Major", "input": "A deviation in the lyophilisation cycle caused the primary drying shelf temperature to exceed the validated set point by 6 degrees for 20 minutes, with unknown impact on product cake structure."}
{"id": "sev-14", "task": "classification", "expected": "Minor", "input": "A standard operating procedure referenced an internal department name that had since been renamed, but all described responsibilities and steps remained accurate and current."}
{"id": "sev-15", "task": "classification", "expected": "Critical", "input": "Water for injection sampled from a distribution loop user point returned an endotoxin result above the pharmacopoeial limit, and this water was used to compound a parenteral batch."}
